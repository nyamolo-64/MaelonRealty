{
  "name": "RoommateProfile",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Student's full name"
    },
    "university": {
      "type": "string",
      "enum": [
        "Strathmore University",
        "University of Nairobi",
        "USIU-Africa",
        "Kenyatta University",
        "JKUAT",
        "Other"
      ],
      "description": "University the student attends"
    },
    "course": {
      "type": "string",
      "description": "Course / programme of study"
    },
    "year_of_study": {
      "type": "string",
      "enum": [
        "1st Year",
        "2nd Year",
        "3rd Year",
        "4th Year",
        "Postgraduate"
      ],
      "description": "Current year of study"
    },
    "gender": {
      "type": "string",
      "enum": [
        "Male",
        "Female",
        "Non-binary",
        "Prefer not to say"
      ]
    },
    "age": {
      "type": "number",
      "description": "Student's age"
    },
    "phone": {
      "type": "string"
    },
    "budget_min": {
      "type": "number",
      "description": "Minimum monthly budget in KES"
    },
    "budget_max": {
      "type": "number",
      "description": "Maximum monthly budget in KES"
    },
    "preferred_location": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Preferred Nairobi neighborhoods"
    },
    "move_in_date": {
      "type": "string",
      "format": "date"
    },
    "lease_duration": {
      "type": "string",
      "enum": [
        "1-3 months",
        "3-6 months",
        "6-12 months",
        "1 year+"
      ]
    },
    "sleep_schedule": {
      "type": "string",
      "enum": [
        "Early bird (before 10pm)",
        "Night owl (after midnight)",
        "Flexible"
      ]
    },
    "study_environment": {
      "type": "string",
      "enum": [
        "Quiet at all times",
        "Moderate noise okay",
        "Social & lively fine"
      ]
    },
    "cleanliness": {
      "type": "string",
      "enum": [
        "Very tidy \u2014 everything in its place",
        "Reasonably clean",
        "Relaxed about mess"
      ]
    },
    "guests": {
      "type": "string",
      "enum": [
        "Rarely / never",
        "Occasionally on weekends",
        "Frequently"
      ]
    },
    "smoking": {
      "type": "boolean"
    },
    "pets": {
      "type": "boolean"
    },
    "cooking_frequency": {
      "type": "string",
      "enum": [
        "Cook every day",
        "A few times a week",
        "Rarely \u2014 mainly takeout"
      ]
    },
    "social_level": {
      "type": "string",
      "enum": [
        "Very social \u2014 love hanging out",
        "Balanced",
        "Prefer my own space"
      ]
    },
    "work_from_home": {
      "type": "boolean"
    },
    "preferred_roommate_gender": {
      "type": "string",
      "enum": [
        "Same gender only",
        "Any gender",
        "No preference"
      ]
    },
    "interests": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Hobbies and interests"
    },
    "about_me": {
      "type": "string",
      "description": "Short bio"
    },
    "room_type": {
      "type": "string",
      "enum": [
        "Single room in shared house",
        "Shared room (bunk)",
        "Bedsitter",
        "Studio",
        "Any"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "matched",
        "paused"
      ],
      "default": "active"
    }
  },
  "required": [
    "full_name",
    "university",
    "year_of_study",
    "budget_min",
    "budget_max"
  ]
}